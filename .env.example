# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

SPRING_PROFILES_ACTIVE=docker

# MySQL
MYSQL_ROOT_PASSWORD=root@1234

# JWT
JWT_SECRET_KEY=5367566B59703373367639792F423F4528482B4D6251655468576D5A71347437
JWT_EXPIRATION=86400000

# Database (prod only)
DB_URL=jdbc:mysql://your-db-host:3306/your_db
DB_USERNAME=your_db_user
DB_PASSWORD=root@1234

# RabbitMQ (prod only)
RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Eureka (prod only)
EUREKA_URL=http://your-eureka-host:8761/eureka/

# Zipkin (prod only)
ZIPKIN_URL=http://your-zipkin-host:9411/api/v2/spans
