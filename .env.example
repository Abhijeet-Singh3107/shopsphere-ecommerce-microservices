# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# -----------------------------------------------
# Profile: docker | prod
# For local dev, no .env needed (defaults to dev)
# -----------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------
# MySQL root password (used by the mysql container)
# -----------------------------------------------
MYSQL_ROOT_PASSWORD=root@1234

# -----------------------------------------------
# JWT (all services share the same secret)
# -----------------------------------------------
JWT_SECRET_KEY=5367566B59703373367639792F423F4528482B4D6251655468576D5A71347437
JWT_EXPIRATION=86400000

# -----------------------------------------------
# Database — prod only (docker profile uses mysql container, no need to set these)
# Each service has its own DB, set all four
# -----------------------------------------------
AUTH_DB_URL=jdbc:mysql://your-db-host:3306/auth_db
AUTH_DB_USERNAME=your_db_user
AUTH_DB_PASSWORD=your_db_password

CATALOG_DB_URL=jdbc:mysql://your-db-host:3306/catalog_db
CATALOG_DB_USERNAME=your_db_user
CATALOG_DB_PASSWORD=your_db_password

ORDER_DB_URL=jdbc:mysql://your-db-host:3306/order_db
ORDER_DB_USERNAME=your_db_user
ORDER_DB_PASSWORD=your_db_password

ADMIN_DB_URL=jdbc:mysql://your-db-host:3306/admin_db
ADMIN_DB_USERNAME=your_db_user
ADMIN_DB_PASSWORD=your_db_password

# -----------------------------------------------
# RabbitMQ — prod only
# -----------------------------------------------
RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# -----------------------------------------------
# Eureka — prod only
# -----------------------------------------------
EUREKA_URL=http://your-eureka-host:8761/eureka/

# -----------------------------------------------
# Zipkin — prod only
# -----------------------------------------------
ZIPKIN_URL=http://your-zipkin-host:9411/api/v2/spans
